# ===========================================
# ZappNews.ai Configuration
# ===========================================

# DATABASE MODE: 'local' (SQLite) or 'supabase'
DB_MODE=local

# Local SQLite path (when DB_MODE=local)
SQLITE_PATH=./data/zappnews.db

# Supabase (only needed if DB_MODE=supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# LLM PROVIDER: 'openrouter' (free!) or 'openai'
# ===========================================
LLM_PROVIDER=openrouter

# OpenRouter (50 free requests - recommended!)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# OpenAI (optional, if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-openai-key

# ===========================================
# TELEGRAM (Required)
# ===========================================
# 1. Message @BotFather on Telegram
# 2. Create bot with /newbot
# 3. Copy the token below
TELEGRAM_BOT_TOKEN=your-bot-token

# To get chat ID:
# 1. Message your bot
# 2. Visit: https://api.telegram.org/bot<TOKEN>/getUpdates
# 3. Find "chat":{"id":123456789}
TELEGRAM_CHAT_ID=your-chat-id

# ===========================================
# OPTIONAL: Additional Sources
# ===========================================

# Reddit (get at reddit.com/prefs/apps)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ZappNewsBot/1.0

# YouTube Data API
# YOUTUBE_API_KEY=

# ===========================================
# SCHEDULING (Cron expressions - UTC timezone)
# ===========================================

# How often to fetch news (default: every hour)
FETCH_CRON=0 * * * *

# When to send digest (default: 5 min past each hour)
DIGEST_CRON=5 * * * *

# Minimum items needed to send a digest
MIN_ITEMS_FOR_DIGEST=3

# ===========================================
# SERVER
# ===========================================
PORT=3000
NODE_ENV=development
