# Supabase (optional - for cloud mode)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL (for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Twitter/X OAuth 2.0 (https://developer.twitter.com)
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# LinkedIn OAuth (https://www.linkedin.com/developers)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Meta/Threads OAuth (https://developers.facebook.com)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# Reddit OAuth (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
